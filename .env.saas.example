# Core app
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your-solana-private-key-base58

# AI
OPENAI_API_KEY=your-openai-api-key

# SaaS API access keys (id:key:plan, comma separated)
SAAS_API_KEYS=team-a:<GENERATE_STRONG_KEY>:pro,team-b:<GENERATE_STRONG_KEY>:enterprise

# Rate limit
SAAS_RATE_LIMIT_MAX=120
SAAS_RATE_LIMIT_WINDOW_MS=60000

# Queue backend config
QUEUE_BACKEND=memory
REDIS_URL=redis://redis:6379
TASK_RETRY_DELAY_MS=500
