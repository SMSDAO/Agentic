# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your-solana-private-key-base58

# Helius
NEXT_PUBLIC_HELIUS_API_KEY=your-helius-api-key

# Jupiter
NEXT_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6

# CoinGecko
COINGECKO_API_KEY=your-coingecko-pro-api-key

# Pyth
NEXT_PUBLIC_PYTH_NETWORK=mainnet-beta

# OpenAI (for DALL-E and LangChain)
OPENAI_API_KEY=your-openai-api-key

# Vercel AI SDK
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# PumpPortal
PUMPPORTAL_API_KEY=your-pumpportal-api-key

# deBridge
DEBRIDGE_API_KEY=your-debridge-api-key

# 3.Land
THREELAND_API_KEY=your-3land-api-key

# Light Protocol
LIGHT_PROTOCOL_RPC=your-light-protocol-rpc

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# SaaS API access (id:key:plan,id:key:plan)
SAAS_API_KEYS=default-dev:dev-local-key:free
SAAS_RATE_LIMIT_MAX=60
SAAS_RATE_LIMIT_WINDOW_MS=60000

# Runtime queue
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379
TASK_RETRY_DELAY_MS=500
